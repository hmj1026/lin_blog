# 開發工具與 AI 助手設定
.claude
.agent
.worktrees
.codex
prompt.md
features
.shared

# 程式碼智能索引 (GitNexus，含大型索引檔，不進版控)
.gitnexus/

# 開發規格文件
# 僅追蹤 openspec/specs/（SSOT capability 規格）；changes/ 與 archive/ 維持本機
openspec/*
!openspec/specs/

# IDE 設定
.vscode
.idea
*.swp
*.swo
*~

# 作業系統
.DS_Store
Thumbs.db

# 相依套件
node_modules/

# 環境變數 (敏感資料)
# 忽略所有 .env 變體，僅保留範例檔
.env*
!.env.example

# 上傳目錄
web/storage/uploads
web/public/uploads

# Docker 生產資料
postgres_data/
blog_storage/

# 部署相關 (實際部署的設定檔存在伺服器上)
# 專案內保留模板檔案，Git 只需追蹤範例
docs/private/
.hyperweave/
.playwright-cli/