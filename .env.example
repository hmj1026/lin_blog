# ===================================================
# Lin Blog - 環境變數範例
# ===================================================
# 複製此檔案為 .env 並填入正確的值
# cp .env.example .env
#
# 本地開發：在 web/ 目錄建立 symlink
# cd web && ln -sf ../.env .env
# ===================================================

# ---------------------------------------------------
# 環境識別
# ---------------------------------------------------
NODE_ENV="development"           # development | production | test
APP_ENV="local"                  # local | staging | production
NEXT_PUBLIC_APP_ENV="local"      # 前端可見

# ---------------------------------------------------
# 應用程式 Port（Docker 部署用）
# ---------------------------------------------------
BLOG_PORT=3100

# ---------------------------------------------------
# 資料庫設定
# ---------------------------------------------------
# Docker 部署用
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=lin_blog
POSTGRES_PORT=5432

# Prisma 連線字串
# 本地開發: postgresql://user:password@localhost:5432/lin_blog
# Docker:   postgresql://blog_user:your-strong-password-here@postgres:5432/lin_blog
DATABASE_URL="postgresql://user:password@localhost:5432/lin_blog"

# ---------------------------------------------------
# NextAuth 認證
# ---------------------------------------------------
NEXTAUTH_SECRET="replace-with-random-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------
# 前端公開變數
# ---------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_UPLOAD_BASE_URL="http://localhost:3000"

# ---------------------------------------------------
# Storage - 檔案上傳儲存設定
# ---------------------------------------------------
STORAGE_PROVIDER="local"         # local | memory | s3 | r2 | gcs
UPLOAD_MAX_FILE_SIZE_MB="10"     # 單檔上傳大小上限（MB）

# 圖片壓縮設定
UPLOAD_IMAGE_COMPRESSION="true"  # 啟用圖片壓縮（預設 true）
UPLOAD_IMAGE_MAX_WIDTH="1920"    # 最大寬度（預設 1920）
UPLOAD_IMAGE_QUALITY="85"        # 壓縮品質 1-100（預設 85）

# 雲端 Storage 設定（僅在使用 s3/r2/gcs 時需要）
# STORAGE_BUCKET="your-bucket-name"
# STORAGE_REGION="us-east-1"                              # S3 region
# STORAGE_ENDPOINT="https://xxx.r2.cloudflarestorage.com" # R2/S3-compatible
# STORAGE_ACCESS_KEY_ID="your-access-key"
# STORAGE_SECRET_ACCESS_KEY="your-secret-key"

# GCS 設定（僅 provider=gcs 時需要）
# GCS_PROJECT_ID="your-project-id"
# GCS_CLIENT_EMAIL="service-account@project.iam.gserviceaccount.com"
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# ---------------------------------------------------
# 外部服務
# ---------------------------------------------------
FIGMA_TOKEN=""
UPLOADTHING_TOKEN=""
CRON_SECRET="replace-with-cron-secret-min-32-chars"

# ---------------------------------------------------
# Analytics (Optional)
# ---------------------------------------------------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""

# ---------------------------------------------------
# Newsletter 訂閱 - Google reCAPTCHA v2（Optional，缺任一值時伺服器 fail closed）
# ---------------------------------------------------
# 前端 checkbox 用的 site key（可公開）
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-v2-site-key"
# 伺服器驗證用的 secret key（絕不可外流或出現在日誌/回應中）
# RECAPTCHA_SECRET_KEY="your-recaptcha-v2-secret-key"
# Google 驗證結果允許的 hostname 清單，逗號分隔（缺少或不符即 fail closed）
# RECAPTCHA_ALLOWED_HOSTNAMES="example.com,www.example.com"

# ---------------------------------------------------
# Newsletter 訂閱 - 專用限流（Optional，皆有預設值）
# ---------------------------------------------------
# 限流視窗長度（秒），必須為正整數且不得超過內建上限
NEWSLETTER_RATE_LIMIT_WINDOW_SECONDS=600
# 視窗內每一來源雜湊允許的最大請求數，必須為正整數且不得超過內建上限
NEWSLETTER_RATE_LIMIT_MAX=5
# 目前部署的 process/replica 數量，預設 1。
# newsletter 限流器為 process-local 實作，APP_REPLICA_COUNT > 1 時建構會直接失敗，
# 水平擴展前必須先把限流 port 換成共享 store（例如 Redis）。
# APP_REPLICA_COUNT=1
# 來源雜湊（HMAC-SHA256）用的密鑰，用於限流器內部雜湊 IP 等來源識別字串，
# 避免低熵輸入（如 IPv4）被預先計算雜湊反查。未設定時會自動產生 per-process
# 隨機密鑰（process 重啟即重置）；如需跨重啟維持一致的雜湊，才需手動設定。
# NEWSLETTER_SOURCE_HASH_SECRET="a-long-random-secret-string"
