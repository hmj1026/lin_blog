# ===================================================
# Lin Blog (web/) - 環境變數範本
# ===================================================
# 這是範本檔案，請複製為 .env 後填入實際值：
#   cp .env.example .env
#
# 變數會經由 Zod schema 驗證，來源檔案：
#   - web/src/env.ts        （伺服端完整 schema，server-only）
#   - web/src/env.public.ts （前端可見的 NEXT_PUBLIC_* 子集）
#   - web/src/env.auth.ts   （NextAuth 專用最小 schema）
# 新增/修改變數時，請同步更新對應的 schema 與本檔案。
# ===================================================

# ---------------------------------------------------
# 環境識別（選用，皆有預設值）
# ---------------------------------------------------
# 選用：Node 執行環境，預設 development
NODE_ENV="development"
# 選用：應用程式環境識別，預設 local
APP_ENV="local"

# ---------------------------------------------------
# 資料庫（必要）
# ---------------------------------------------------
# 必要：Prisma 連線字串（需為合法 URL）
DATABASE_URL="postgresql://user:password@localhost:5432/lin_blog"

# ---------------------------------------------------
# 認證 / NextAuth（必要）
# ---------------------------------------------------
# 必要：NextAuth JWT 簽章密鑰（至少 1 字元，建議 32 字元以上隨機字串）
NEXTAUTH_SECRET="replace-with-random-secret-min-32-chars"
# 必要（NextAuth 慣例變數，未在 Zod schema 中驗證，但正式環境運作必須提供）：NextAuth 對外基準 URL
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------
# 排程任務（必要）
# ---------------------------------------------------
# 必要：受保護 Cron API 端點的驗證密鑰（至少 1 字元，建議 32 字元以上隨機字串）
CRON_SECRET="replace-with-cron-secret-min-32-chars"

# ---------------------------------------------------
# 外部服務（選用）
# ---------------------------------------------------
# 選用：Figma API token（若無整合 Figma 可留空）
FIGMA_TOKEN=""
# 選用：UploadThing API token（若無使用 UploadThing 可留空）
UPLOADTHING_TOKEN=""

# ---------------------------------------------------
# Storage - 檔案上傳儲存設定（選用，皆有預設值或依 provider 決定）
# ---------------------------------------------------
# 選用：儲存供應商，local | memory | s3 | r2 | gcs，預設 local
STORAGE_PROVIDER="local"
# 選用：local provider 使用相對路徑時的本地根目錄
STORAGE_LOCAL_ROOT_DIR=""
# 選用：單檔上傳大小上限（MB），預設 10
UPLOAD_MAX_FILE_SIZE_MB="10"
# 選用：是否啟用圖片上傳壓縮，預設 true
UPLOAD_IMAGE_COMPRESSION="true"
# 選用：圖片壓縮後最大寬度，預設 1920
UPLOAD_IMAGE_MAX_WIDTH="1920"
# 選用：圖片壓縮品質 1-100，預設 85
UPLOAD_IMAGE_QUALITY="85"

# 雲端 Storage 設定（僅在 STORAGE_PROVIDER=s3/r2 時需要，其餘情況選用）
# 選用：物件儲存 bucket 名稱
STORAGE_BUCKET=""
# 選用：S3 region
STORAGE_REGION=""
# 選用：S3 相容端點（如 R2）
STORAGE_ENDPOINT=""
# 選用：物件儲存 access key id
STORAGE_ACCESS_KEY_ID=""
# 選用：物件儲存 secret access key
STORAGE_SECRET_ACCESS_KEY=""

# GCS 設定（僅在 STORAGE_PROVIDER=gcs 時需要，其餘情況選用）
# 選用：GCS 專案 ID
GCS_PROJECT_ID=""
# 選用：GCS 服務帳戶 email
GCS_CLIENT_EMAIL=""
# 選用：GCS 服務帳戶私鑰（PEM 格式，換行以 \n 表示）
GCS_PRIVATE_KEY=""

# ---------------------------------------------------
# 前端公開變數 NEXT_PUBLIC_*（選用，皆有預設值或可留空）
# ---------------------------------------------------
# 選用：前端可見的應用程式環境識別，預設 local
NEXT_PUBLIC_APP_ENV="local"
# 選用：對外公開的網站 URL（合法 URL 格式，空字串視為未設定）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# 選用：上傳檔案對外存取的 Base URL（合法 URL 格式，空字串視為未設定）
NEXT_PUBLIC_UPLOAD_BASE_URL="http://localhost:3000"

# ---------------------------------------------------
# Analytics（選用）
# ---------------------------------------------------
# 選用：Google Analytics 追蹤 ID
NEXT_PUBLIC_GA_ID=""
# 選用：Google Tag Manager 容器 ID
NEXT_PUBLIC_GTM_ID=""
# 選用：Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=""
